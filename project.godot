; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

resources_spreadsheet_view/array_color_tint=100.0
resources_spreadsheet_view/color_rows=true
resources_spreadsheet_view/array_min_width=128.0
resources_spreadsheet_view/resource_preview_size=32.0
resources_spreadsheet_view/clip_headers=false
resources_spreadsheet_view/dupe_arrays=true
resources_spreadsheet_view/context_menu_on_leftclick=false
resources_spreadsheet_view/fold_docks=true
resources_spreadsheet_view/resource_cell_label_mode=1
resources_spreadsheet_view/freeze_first_column=true

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="GapWander"
run/main_scene="uid://ccxpkqt8i0t40"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="uid://cvnt8roa80q01"

[autoload]

GameManager="*res://Script/GameManager.gd"
ConfigManager="*res://Script/ConfigManager.gd"
DialogueManager="*uid://c3rodes2l3gxb"
InputHelper="*uid://cholww48njaeh"
PhantomCameraManager="*uid://duq6jhf6unyis"
SoundManager="*uid://b7oohye0vv0xo"
SceneManager="*uid://es4who1odjys"
Scenes="*uid://dhdcae0udnw05"
NetHandler="*res://Script/Net/NetHandler.gd"

[debug]

gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[dialogue_manager]

runtime/balloon_path="res://Prefab/Dialogue/balloon.tscn"

[display]

window/size/viewport_width=1980
window/size/viewport_height=1080

[dotnet]

project/assembly_name="GapWander"

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg", "res://addons/csv-data-importer/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/ef_ds_uids/plugin.cfg", "res://addons/gdfxr/plugin.cfg", "res://addons/godot_state_charts/plugin.cfg", "res://addons/input_helper/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/pre_run_dka/plugin.cfg", "res://addons/resources_spreadsheet_view/plugin.cfg", "res://addons/scene_manager/plugin.cfg", "res://addons/script-ide/plugin.cfg", "res://addons/sound_manager/plugin.cfg")

